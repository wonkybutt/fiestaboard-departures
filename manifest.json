{
  "id": "departures",
  "name": "Departures",
  "author": "Adam",
  "version": "1.0.0",
  "description": "Countdown to multiple events from public webcal feed",
  "icon": "clock",
  "category": "utility",
  "min_refresh_seconds": 60,
  "settings_schema": {
    "type": "object",
    "properties": {
      "calendar_url": {
        "type": "string",
        "title": "ICS URL"
      },
      "timezone": {
        "type": "string",
        "title": "Timezone",
        "default": "America/Anchorage"
      },
      "max_events": {
        "type": "integer",
        "title": "Max Events",
        "default": 6
      },
      "refresh_seconds": {
        "type": "integer",
        "title": "Refresh Interval (seconds)",
        "default": 300,
        "minimum": 60
      }
    }
  }
}